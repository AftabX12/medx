APP_ENV=dev
APP_DEBUG=true

# Postgres — start the DB with: docker compose up postgres -d
DATABASE_URL=postgresql+asyncpg://medx:medx@localhost:5433/medx

JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

DOCUMENT_STORE=local
LOCAL_STORE_PATH=./uploads

# AI provider: "openrouter" (cloud) or "ollama" (local)
AI_PROVIDER=openrouter

# OpenRouter — Get a key at https://openrouter.ai/keys. Free-tier models work for R&D.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_TITLE=MedX

# Ollama — local LLM server (used when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:latest

# Single model ID used for all AI tasks when AI_PROVIDER=openrouter.
# When AI_PROVIDER=ollama, OLLAMA_MODEL is used instead.
OPENROUTER_MODEL=deepseek/deepseek-chat-v3:free

# OCR engine: "pypdf" (default, text-layer only) | "openrouter" (cloud VLM) | "ollama" (local VLM)
# pypdf  — no AI, works for digital PDFs with a text layer
# openrouter — vision OCR via OPENROUTER_MODEL
# ollama     — vision OCR via OLLAMA_MODEL; add OLLAMA_VISION_MODEL=<model> here if you want
#              a separate multimodal model just for OCR (e.g. OLLAMA_MODEL=llama3 + OLLAMA_VISION_MODEL=llava)
OCR_ENGINE=pypdf

# Background queue: "inprocess" now; swap to "arq" when Redis is introduced (Phase 5).
QUEUE_BACKEND=inprocess
QUEUE_MAX_CONCURRENCY=2

# Seed admin — created automatically on first startup if the email doesn't exist.
# Change these before deploying to production.
SEED_TENANT_NAME=MedX
SEED_ADMIN_EMAIL=admin@medx.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Admin
