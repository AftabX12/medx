APP_ENV=dev
APP_DEBUG=true

# Dev default: SQLite file-based, zero infra.
# Switch to Postgres later by swapping to the commented URL and running the app on docker compose.
DATABASE_URL=sqlite+aiosqlite:///./medx.db
# DATABASE_URL=postgresql+asyncpg://medx:medx@localhost:5433/medx

JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

DOCUMENT_STORE=local
LOCAL_STORE_PATH=./uploads

ANTHROPIC_API_KEY=
