APP_ENV=dev
APP_DEBUG=true

# Postgres — start the DB with: docker compose up postgres -d
DATABASE_URL=postgresql+asyncpg://medx:medx@localhost:5433/medx

JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

DOCUMENT_STORE=local
LOCAL_STORE_PATH=./uploads

# OpenRouter — OpenAI-compatible API for all AI calls (classify/extract/vision OCR).
# Get a key at https://openrouter.ai/keys. Free-tier models work for R&D.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_TITLE=MedX

# Per-role model IDs. Free-tier names churn; update here without touching code.
AI_MODEL_CLASSIFY=google/gemini-2.0-flash-exp:free
AI_MODEL_EXTRACT=deepseek/deepseek-chat-v3:free
AI_MODEL_EXTRACT_ALT=meta-llama/llama-3.3-70b-instruct:free
AI_MODEL_VISION_OCR=qwen/qwen2.5-vl-72b-instruct:free
AI_MODEL_SUMMARIZE=google/gemini-2.0-flash-exp:free
AI_MODEL_SYNTHETIC_GEN=deepseek/deepseek-chat-v3:free

# OCR engine: "openrouter_vision" (default, free VLM) | "marker" (local, requires .[ocr-local])
OCR_ENGINE=openrouter_vision
OCR_MAX_PAGES=30

# Background queue: "inprocess" now; swap to "arq" when Redis is introduced (Phase 5).
QUEUE_BACKEND=inprocess
QUEUE_MAX_CONCURRENCY=2

# Seed admin — created automatically on first startup if the email doesn't exist.
# Change these before deploying to production.
SEED_TENANT_NAME=MedX
SEED_ADMIN_EMAIL=admin@medx.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Admin
